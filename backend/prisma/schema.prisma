// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CarbonProject {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  name                String
  description         String?  @db.Text
  methodology         String
  country             String
  projectType         String
  status              String   @default("Pending")
  vintageYear         Int
  methodologyScore    Int
  totalCreditsIssued  Decimal  @default(0) @db.Decimal(18, 2)
  totalCreditsRetired Decimal  @default(0) @db.Decimal(18, 2)
  metadataCid         String
  verifierAddress     String
  ownerAddress        String
  coordinates         Json?
  lastMonitoringAt    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  ipfsFiles           IPFSFile[]

  batches     CreditBatch[]
  retirements RetirementRecord[]
  listings    MarketListing[]
  monitoring  MonitoringData[]

  @@index([methodology])
  @@index([country])
  @@index([status])
  @@index([vintageYear])
  @@index([createdAt])
  @@index([methodology, country, status])
  @@index([lastMonitoringAt])
}

model CreditBatch {
  id          String   @id @default(cuid())
  batchId     String   @unique
  projectId   String
  vintageYear Int
  amount      Decimal  @db.Decimal(18, 2)
  serialStart String
  serialEnd   String
  status      String   @default("Active")
  metadataCid String
  issuedAt    DateTime @default(now()) @db.Timestamptz

  project     CarbonProject      @relation(fields: [projectId], references: [projectId])
  retirements RetirementRecord[]
  listings    MarketListing[]
  ipfsFiles   IPFSFile[]
}

model RetirementRecord {
  id               String   @id @default(cuid())
  retirementId     String   @unique
  batchId          String
  projectId        String
  amount           Decimal  @db.Decimal(18, 2)
  retiredBy        String
  beneficiary      String
  retirementReason String
  vintageYear      Int
  serialStart      String
  serialEnd        String
  serialNumbers    String[]
  txHash           String
  certificateCid   String?
  isValid          Boolean  @default(true)
  validatedAt      DateTime?
  retiredAt        DateTime @default(now())

  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
  project CarbonProject @relation(fields: [projectId], references: [projectId])
  ipfsFiles IPFSFile[]
}

model MarketListing {
  id              String   @id @default(cuid())
  listingId       String   @unique
  projectId       String
  batchId         String
  seller          String
  amountAvailable Decimal  @db.Decimal(18, 2)
  pricePerCredit  String
  vintageYear     Int
  methodology     String
  country         String
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project CarbonProject @relation(fields: [projectId], references: [projectId])
  batch   CreditBatch   @relation(fields: [batchId], references: [batchId])
}

model MonitoringData {
  id               String   @id @default(cuid())
  projectId        String
  period           String
  tonnesVerified   Decimal  @db.Decimal(18, 2)
  methodologyScore Int
  satelliteCid     String
  submittedBy      String
  submittedAt      DateTime @default(now())

  project CarbonProject @relation(fields: [projectId], references: [projectId])

  @@unique([projectId, period])
}

model OracleUpdate {
  id               String    @id @default(cuid())
  idempotencyKey   String    @unique  // projectId:period or methodology:vintageYear
  type             String    // "monitoring" | "price"
  projectId        String?
  period           String?
  tonnesVerified   Decimal?  @db.Decimal(18, 2)
  methodologyScore Int?
  methodology      String?
  vintageYear      Int?
  priceUsdc        String?
  txHash           String?
  status           String    @default("pending")  // pending | submitted | failed
  attempts         Int       @default(0)
  lastError        String?
  submittedAt      DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([projectId])
}

model User {
  id                      String                   @id @default(cuid())
  publicKey               String                   @unique
  email                   String?                  @unique
  role                    String                   @default("corporation")
  isSubscribed            Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  notificationPreferences NotificationPreference?
}

model NotificationPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  projectApproved     Boolean  @default(true)
  creditsMinted       Boolean  @default(true)
  purchaseConfirmed   Boolean  @default(true)
  retirementConfirmed Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EmailLog {
  id        String    @id @default(cuid())
  to        String
  subject   String
  template  String
  status    String    @default("Pending") // Pending | Sent | Failed
  error     String?
  txHash    String?   // If related to a transaction
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([to])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resourceId String?
  ipAddress  String?
  result     String?  // e.g., "Success", "Failure: <error>"
  metadata   Json?    // Optional extra info
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resourceId])
  @@index([timestamp])
}

model SyncMetadata {
  id                String   @id @default("singleton")
  lastIndexedLedger Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model Job {
  id          String    @id @default(cuid())
  queue       String
  type        String
  payload     Json
  status      String    @default("waiting")  // waiting | active | completed | failed | dead
  attempts    Int       @default(0)
  result      Json?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([queue, status])
  @@index([type])
}

model IPFSFile {
  id              String   @id @default(cuid())
  cid             String
  fileName        String
  fileType        String   // "application/pdf" or "application/json"
  fileSize        Int      // in bytes
  pinStatus       String   @default("pending")  // pending | pinned | failed
  linkedEntityType String?  // "project" | "certificate" | "batch"
  linkedEntityId  String?  // ID of the linked entity
  uploadedAt      DateTime @default(now())
  pinnedAt        DateTime?

  project         CarbonProject?  @relation(fields: [projectId], references: [id])
  projectId       String?
  batch           CreditBatch?    @relation(fields: [batchId], references: [id])
  batchId         String?
  retirement      RetirementRecord? @relation(fields: [retirementId], references: [id])
  retirementId    String?

  @@index([cid])
  @@index([pinStatus])
}

model VerifierApplication {
  id               String    @id @default(cuid())
  publicKey        String    @unique
  organizationName String
  accreditationBody String
  accreditationId  String
  contactEmail     String
  documentsCid     String
  status           String    @default("pending")  // pending | approved | rejected
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model PriceApproval {
  id           String   @id @default(cuid())
  methodology  String
  vintageYear  Int
  priceStroops String
  deviation    Float
  status       String   @default("Pending")  // Pending | Approved | Rejected
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
